<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- univerzálne pill tlačidlo -->
    <style name="DesklyPillButton" parent="Widget.MaterialComponents.Button">
        <!-- odstráni Material insets -->
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>

        <!-- neprebíjaj background drawable tintom -->
        <item name="backgroundTint">@null</item>

        <!-- text a zarovnanie -->
        <item name="android:gravity">center</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/button_text</item>

        <!-- rozumné rozmery -->
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingRight">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

    <style name="DesklySectionTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="DesklySectionSubtitle">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="DesklyFieldLabel">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="DesklyIconButton">
        <item name="android:background">@drawable/bg_btn</item>
        <item name="android:padding">12dp</item>
        <item name="android:scaleType">center</item>
    </style>

    <style name="DesklySettingTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="DesklySettingValue">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="DesklySettingSubtitle">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">13sp</item>
    </style>

</resources>
