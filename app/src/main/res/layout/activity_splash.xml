<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/bg_screen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="desklyGO™"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/txtHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quick connect"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="14dp" />

        <!-- DISCOVERY -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tile"
            android:padding="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Zariadenia"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnScan"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="Scan"
                android:textAllCaps="false"
                android:backgroundTint="@color/card"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/txtScanStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pripravené"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDevices"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- MANUAL INPUT (COLLAPSIBLE) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tile"
            android:orientation="vertical"
            android:layout_marginTop="14dp">

            <!-- HEADER (clickable) -->
            <LinearLayout
                android:id="@+id/layoutManualHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Manuálne pripojenie (núdzové)"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txtManualArrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⌄"
                    android:textSize="18sp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <!-- COLLAPSIBLE CONTENT -->
            <LinearLayout
                android:id="@+id/layoutManualContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/edtIp"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="IP adresa"
                    android:inputType="text"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp" />

                <EditText
                    android:id="@+id/edtPort"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:hint="Port"
                    android:inputType="number"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp" />

                <Button
                    android:id="@+id/btnContinue"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:text="Continue"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/card"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PIN a párovanie nájdeš v Deskly PC."
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>
