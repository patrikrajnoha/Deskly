<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#121212"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <!-- STATUS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_tile"
            android:padding="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtConnStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Disconnected"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/txtAuthStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Unauthorized"
                android:textColor="#c6c6c6"
                android:paddingTop="6dp" />
        </LinearLayout>

        <Space android:layout_width="1dp" android:layout_height="14dp"/>

        <!-- CONNECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_tile"
            android:padding="14dp"
            android:orientation="vertical">

            <TextView
                android:text="Connection"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:paddingBottom="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <EditText
                    android:id="@+id/edtIp"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="2"
                    android:hint="IP"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#c6c6c6"
                    android:background="@drawable/bg_pill_input"
                    android:padding="14dp"/>

                <Space android:layout_width="10dp" android:layout_height="1dp"/>

                <EditText
                    android:id="@+id/edtPort"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:hint="Port"
                    android:inputType="number"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#c6c6c6"
                    android:background="@drawable/bg_pill_input"
                    android:padding="14dp"/>
            </LinearLayout>

            <Space android:layout_height="10dp" android:layout_width="1dp"/>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/btnConnect"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Connect"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_pill_btn"/>

                <Space android:layout_width="10dp" android:layout_height="1dp"/>

                <Button
                    android:id="@+id/btnDisconnect"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Disconnect"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_pill_btn"/>
            </LinearLayout>

            <Space android:layout_height="10dp" android:layout_width="1dp"/>

            <Button
                android:id="@+id/btnPing"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Ping"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_pill_btn"/>
        </LinearLayout>

        <Space android:layout_height="14dp" android:layout_width="1dp"/>

        <!-- PAIRING -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_tile"
            android:padding="14dp"
            android:orientation="vertical">

            <TextView
                android:text="Pairing"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:paddingBottom="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/edtPin"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="6-digit PIN"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#c6c6c6"
                android:background="@drawable/bg_pill_input"
                android:padding="14dp"/>

            <Space android:layout_height="10dp" android:layout_width="1dp"/>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/btnPair"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Pair"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_pill_btn"/>

                <Space android:layout_width="10dp" android:layout_height="1dp"/>

                <Button
                    android:id="@+id/btnClearToken"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Clear token"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_pill_btn"/>
            </LinearLayout>
        </LinearLayout>

        <Space android:layout_height="14dp" android:layout_width="1dp"/>

        <!-- TIMER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_tile"
            android:padding="14dp"
            android:orientation="vertical">

            <TextView
                android:text="Timer action"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:paddingBottom="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/btnTimerSleep"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Sleep"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_pill_btn"/>

                <Space android:layout_width="10dp" android:layout_height="1dp"/>

                <Button
                    android:id="@+id/btnTimerShutdown"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Shutdown"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_pill_btn"/>
            </LinearLayout>
        </LinearLayout>

        <Space android:layout_height="14dp" android:layout_width="1dp"/>

        <!-- WOL (ROZBAĽOVACIE) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_tile"
            android:padding="14dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/wolHeader"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Wake-on-LAN"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/wolArrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▾"
                    android:textColor="#c6c6c6"
                    android:textSize="18sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/wolContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingTop="10dp">

                <TextView
                    android:id="@+id/txtInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#c6c6c6"/>

                <EditText
                    android:id="@+id/edtMac"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:hint="MAC (AA:BB:CC:DD:EE:FF)"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#c6c6c6"
                    android:background="@drawable/bg_pill_input"
                    android:padding="14dp"/>

                <EditText
                    android:id="@+id/edtBroadcast"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:hint="Broadcast IP (e.g. 192.168.1.255)"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#c6c6c6"
                    android:background="@drawable/bg_pill_input"
                    android:padding="14dp"/>

                <EditText
                    android:id="@+id/edtWolPort"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:hint="Port (default 9)"
                    android:inputType="number"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#c6c6c6"
                    android:background="@drawable/bg_pill_input"
                    android:padding="14dp"/>

                <Button
                    android:id="@+id/btnSendWol"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:text="Send WOL"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_pill_btn"/>
            </LinearLayout>
        </LinearLayout>

        <Space android:layout_height="24dp" android:layout_width="1dp"/>
    </LinearLayout>
</ScrollView>
