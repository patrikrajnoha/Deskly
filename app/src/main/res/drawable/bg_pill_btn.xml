<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="#15181C"/>
            <stroke android:width="1dp" android:color="#232932"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape>
            <solid android:color="#283039"/>
            <stroke android:width="1dp" android:color="#3B4652"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="@color/card_high"/>
            <stroke android:width="1dp" android:color="@color/card_stroke"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>
