<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_enabled="false">
        <shape>
            <solid android:color="#171717"/>
            <stroke android:width="1dp" android:color="#242424"/>
            <corners android:radius="999dp"/>
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape>
            <solid android:color="#2B2B2B"/>
            <stroke android:width="1dp" android:color="#3A3A3A"/>
            <corners android:radius="999dp"/>
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="#202020"/>
            <stroke android:width="1dp" android:color="#2E2E2E"/>
            <corners android:radius="999dp"/>
        </shape>
    </item>

</selector>
