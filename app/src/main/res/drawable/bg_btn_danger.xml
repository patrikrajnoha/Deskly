<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="@color/colorInput" />
            <stroke android:width="1dp" android:color="@color/colorStroke" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape>
            <solid android:color="#3A2225" />
            <stroke android:width="1dp" android:color="@color/danger" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="@color/danger_surface" />
            <stroke android:width="1dp" android:color="#6F3439" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
